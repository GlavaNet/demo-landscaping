# -------------------------------------------------------
# Copy this file to .env for local development.
# In production, set these as GitHub Actions Secrets.
# -------------------------------------------------------

# Google Drive folder ID (from the folder URL)
# How to get it: open the folder in Drive, copy the ID from
# https://drive.google.com/drive/folders/<FOLDER_ID>
# Make sure the folder is shared as "Anyone with the link - Viewer"
VITE_GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Business display name (shown in nav, footer, and page title)
VITE_BUSINESS_NAME=Your Business Name

# Contact details (shown on Contact page)
VITE_CONTACT_EMAIL=hello@yourbusiness.com
VITE_CONTACT_PHONE=(555) 000-0000

# Short bio / tagline shown on the home page below the gallery
VITE_BIO=Quality work, every time. Serving the local community since 2010.

# Formspree form ID for the contact form
# Create a free form at https://formspree.io — the ID looks like: xabcdefg
VITE_FORMSPREE_ID=your_formspree_id_here

# Optional: Instagram handle for footer link (without the @)
VITE_INSTAGRAM_HANDLE=yourbusiness
